#!/bin/sh
# ---------------------------------------------------------------------------
# Maven Start Up Batch script
#
# Required ENV vars:
# ------------------
#   JAVA_HOME - location of a JDK home dir
#
# Optional ENV vars
# -----------------
#   M2_HOME - location of maven2's installed home dir
#   MAVEN_OPTS - parameters passed to the Java VM when running Maven
#   MAVEN_SKIP_RC - flag to disable loading of mavenrc files
# ---------------------------------------------------------------------------

set -o nounset

MAVEN_HOME=${MAVEN_HOME:-"$HOME/.m2"}
MAVEN_OPTS=${MAVEN_OPTS:-""}

APP_HOME=$( cd "${0%/*}" && pwd -P )

MAVEN_PROJECTBASEDIR=${MAVEN_PROJECTBASEDIR:-"$APP_HOME"}

MAVEN_OPTS="\"$MAVEN_OPTS\""

# Determine the Java command to use to start the JVM.
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        JAVACMD=$JAVA_HOME/jre/sh/java
    else
        JAVACMD=$JAVA_HOME/bin/java
    fi
    if [ ! -x "$JAVACMD" ] ; then
        echo "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME" >&2
        echo "Please set the JAVA_HOME variable in your environment to match the" >&2
        echo "location of your Java installation." >&2
        exit 1
    fi
else
    JAVACMD=java
    which java >/dev/null 2>&1 || {
        echo "ERROR: JAVA_HOME is not set and no 'java' command could be found in your PATH." >&2
        echo "Please set the JAVA_HOME variable in your environment to match the" >&2
        echo "location of your Java installation." >&2
        exit 1
    }
fi

# Increase the maximum file descriptors if we can.
if [ "$(uname -s)" = "Linux" ] ; then
    MAX_FD=$(maximum_writable_fd 2>/dev/null || echo "$(ulimit -H -n)")
    if [ "$MAX_FD" != "unlimited" ] && [ "$(ulimit -n)" -lt "$MAX_FD" ] ; then
        ulimit -n "$MAX_FD" 2>/dev/null || true
    fi
fi

# Use the maximum available, or set MAX_FD != -1 to use that value.
MAX_FD=${MAX_FD:-"maximum"}

warn () {
    echo "$*"
}

die () {
    echo "$*"
    exit 1
}

# Setup the Maven wrapper
MAVEN_JAR="$APP_HOME/.mvn/wrapper/maven-wrapper.jar"
MAVEN_WRAPPER_JAVA_OPTS="$MAVEN_OPTS"
MAVEN_CMD_LINE_ARGS="$@"

# Collect all arguments for the java command;
#   * $DEFAULT_JVM_OPTS, $JAVA_OPTS, and $MAVEN_OPTS can contain fragments of
#     shell script including quotes and/or backslashes, so put them in
#     temporary variables to preserve quoting
eval set -- "$DEFAULT_JVM_OPTS" "$JAVA_OPTS" "$MAVEN_WRAPPER_JAVA_OPTS" \
    "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" \
    "-jar" "$MAVEN_JAR" \
    "$MAVEN_CMD_LINE_ARGS"

exec "$JAVACMD" "$@"
