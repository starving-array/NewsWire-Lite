{
  "__inputs": [],
  "__requires": [],
  "title": "FNMP - Service Overview",
  "uid": "fnmp-service-overview",
  "version": 1,
  "tags": ["fnmp"],
  "timezone": "utc",
  "editable": true,
  "panels": [
    {
      "title": "Request Rate (RED)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{application=\"article-service\"}[1m])",
          "legendFormat": "{{method}} {{uri}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "P99 Latency",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{application=\"article-service\"}[1m]))",
          "legendFormat": "{{method}} {{uri}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{application=\"article-service\", status=~\"5..\"}[1m])",
          "legendFormat": "{{method}} {{uri}}"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 }
    },
    {
      "title": "JVM Memory",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\"}",
          "legendFormat": "{{app}} heap"
        },
        {
          "expr": "jvm_memory_used_bytes{area=\"nonheap\"}",
          "legendFormat": "{{app}} non-heap"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 }
    },
    {
      "title": "DB Connection Pool",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "hikaricp_connections_active",
          "legendFormat": "active"
        },
        {
          "expr": "hikaricp_connections_idle",
          "legendFormat": "idle"
        },
        {
          "expr": "hikaricp_connections_pending",
          "legendFormat": "pending"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 }
    },
    {
      "title": "Recent Logs (Loki)",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{service=\"article-service\"} |= \"$query\""
        }
      ],
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 }
    }
  ],
  "schemaVersion": 38
}