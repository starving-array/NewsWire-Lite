{
  "policy": {
    "description": "FNMP article index lifecycle - hot 7d, warm 30d, cold 90d, delete 365d",
    "default_state": "hot",
    "states": [
      {
        "name": "hot",
        "actions": {
          "rollover": {
            "min_size": "50gb",
            "min_docs": 500000,
            "min_age": "7d"
          },
          "set_priority": {
            "priority": 100
          }
        },
        "transitions": [
          {
            "state_name": "warm",
            "conditions": {
              "min_index_age": "7d"
            }
          }
        ]
      },
      {
        "name": "warm",
        "actions": {
          "read_only": {},
          "force_merge": {
            "max_num_segments": 1
          },
          "set_priority": {
            "priority": 50
          }
        },
        "transitions": [
          {
            "state_name": "cold",
            "conditions": {
              "min_index_age": "30d"
            }
          }
        ]
      },
      {
        "name": "cold",
        "actions": {
          "read_only": {},
          "set_priority": {
            "priority": 0
          }
        },
        "transitions": [
          {
            "state_name": "delete",
            "conditions": {
              "min_index_age": "365d"
            }
          }
        ]
      },
      {
        "name": "delete",
        "actions": {
          "delete": {}
        }
      }
    ]
  }
}
